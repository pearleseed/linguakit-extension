{
  "name": "linguakit",
  "version": "1.0.0",
  "private": true,
  "description": "Chrome extension for instant AI-powered translation on input field.",
  "type": "module",
  "scripts": {
    "lint": "vp lint .",
    "format": "vp fmt . --write",
    "prepare": "vp config",
    "setup-ocr": "node scripts/setup-ocr.js",
    "benchmark": "bun run benchmarks/performance-test.js"
  },
  "dependencies": {
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "vite-plus": "latest"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "bun@1.3.14"
}
